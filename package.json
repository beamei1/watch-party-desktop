{
  "name": "watch-party-desktop",
  "version": "1.0.1",
  "main": "main.js",
  "scripts": {
    "build": "electron-builder --win"
  },
  "dependencies": {
    "electron-updater": "^6.1.8"
  },
  "build": {
    "appId": "com.watchparty.app",
    "productName": "Watch Party",
    "publish": ["github"],
    "win": {
      "target": "nsis",
      "icon": "icon.ico",
      "nsis": {
        "oneClick": false,
        "allowToChangeInstallationDirectory": true,
        "deleteAppDataOnUninstall": true,
        "perMachine": true,
        "runAfterFinish": true,
        "requestElevation": true
      }
    }
  },
  "devDependencies": {
    "electron": "^29.0.0",
    "electron-builder": "^24.13.3"
  }
}
